---
/**
 * VideoEmbed — lazy-loading facade for Vimeo and YouTube
 *
 * Usage:
 *   <VideoEmbed vimeoId="123456789" title="My Showreel" />
 *   <VideoEmbed youtubeId="dQw4w9WgXcQ" title="Brand Film" />
 *
 * Performance: Shows a thumbnail placeholder until clicked.
 * Only loads the heavy iframe JS after user interaction.
 */
interface Props {
  vimeoId?:   string;
  youtubeId?: string;
  title?:     string;
  autoplay?:  boolean;
}

const { vimeoId, youtubeId, title = 'Video', autoplay = false } = Astro.props;

if (!vimeoId && !youtubeId) {
  throw new Error('VideoEmbed requires either a vimeoId or youtubeId prop.');
}

// Build thumbnail and embed URLs
const isVimeo = Boolean(vimeoId);
const thumbSrc  = isVimeo
  ? `https://vumbnail.com/${vimeoId}.jpg`
  : `https://img.youtube.com/vi/${youtubeId}/maxresdefault.jpg`;

const embedUrl = isVimeo
  ? `https://player.vimeo.com/video/${vimeoId}?autoplay=1&color=ccff00&title=0&byline=0&portrait=0`
  : `https://www.youtube.com/embed/${youtubeId}?autoplay=1&rel=0`;
---

<div
  class="video-facade"
  data-embed-url={embedUrl}
  data-title={title}
  role="button"
  tabindex="0"
  aria-label={`Play ${title}`}
>
  <!-- Thumbnail -->
  <img
    src={thumbSrc}
    alt={`Thumbnail for ${title}`}
    loading="lazy"
    decoding="async"
  />

  <!-- Play button overlay -->
  <div class="play-overlay" aria-hidden="true">
    <div class="play-btn">
      <svg width="20" height="22" viewBox="0 0 20 22" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M1 1.5L19 11L1 20.5V1.5Z" fill="currentColor"/>
      </svg>
    </div>
    {title && <p class="video-title">{title}</p>}
  </div>
</div>

<script>
  document.querySelectorAll<HTMLElement>('.video-facade').forEach(facade => {
    const activate = () => {
      const url = facade.dataset.embedUrl;
      const title = facade.dataset.title ?? 'Video';
      if (!url) return;

      const iframe = document.createElement('iframe');
      iframe.src = url;
      iframe.title = title;
      iframe.allow = 'autoplay; fullscreen; picture-in-picture';
      iframe.allowFullscreen = true;
      iframe.style.cssText = 'position:absolute;inset:0;width:100%;height:100%;border:0;';

      // Replace facade contents with iframe
      facade.innerHTML = '';
      facade.style.cursor = 'default';
      facade.appendChild(iframe);
      facade.removeEventListener('click', activate);
      facade.removeEventListener('keydown', onKey);
    };

    const onKey = (e: KeyboardEvent) => {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        activate();
      }
    };

    facade.addEventListener('click', activate);
    facade.addEventListener('keydown', onKey);
  });
</script>

<style>
  .video-facade {
    position: relative;
    aspect-ratio: 16 / 9;
    width: 100%;
    background-color: var(--color-surface);
    overflow: hidden;
    cursor: pointer;
    border-radius: 4px;
  }

  .video-facade img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 400ms ease, filter 400ms ease;
    filter: brightness(0.75);
  }

  .video-facade:hover img {
    transform: scale(1.02);
    filter: brightness(0.55);
  }

  .play-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1rem;
  }

  .play-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 72px;
    height: 72px;
    background-color: var(--color-accent);
    color: var(--color-bg);
    border-radius: 50%;
    transition: transform 200ms ease, background-color 200ms ease;
    flex-shrink: 0;
  }

  .video-facade:hover .play-btn {
    transform: scale(1.08);
  }

  .video-title {
    font-family: var(--font-family-display);
    font-weight: 600;
    font-size: 0.85rem;
    letter-spacing: 0.05em;
    color: var(--color-text);
    text-align: center;
    padding: 0 1rem;
  }
</style>

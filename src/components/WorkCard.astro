---
/**
 * WorkCard — A24-inspired image-first card.
 * Title only appears on hover. No borders, no backgrounds — just the image.
 */
interface Props {
  title:       string;
  cover:       string;
  coverAlt?:   string;
  slug:        string;
  section:     'editorial' | 'personal';
  client?:     string;
  orientation?: 'landscape' | 'portrait';
}

const { title, cover, coverAlt, slug, section, client, orientation = 'landscape' } = Astro.props;
---

<a href={`/${section}/${slug}`} class={`work-card${orientation === 'portrait' ? ' is-portrait' : ''}`}>
  <div class="img-wrap">
    <img
      src={cover}
      alt={coverAlt ?? title}
      loading="lazy"
      decoding="async"
    />
    <div class="overlay" aria-hidden="true">
      <p class="overlay-title">{title}</p>
      {client && <p class="overlay-client">{client}</p>}
    </div>
  </div>
  {client && <p class="card-caption">{client}</p>}
</a>

<style>
  .work-card {
    display: block;
    overflow: hidden;
    height: 100%;
  }

  /* Portrait cards span 2 grid rows */
  .work-card.is-portrait {
    grid-row: span 2;
  }

  .img-wrap {
    position: relative;
    height: 100%;
    overflow: hidden;
    background-color: var(--color-surface);
  }

  .img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 600ms cubic-bezier(0.25, 0.46, 0.45, 0.94),
                filter 400ms ease;
    will-change: transform;
  }

  .work-card:hover .img-wrap img {
    transform: scale(1.04);
    filter: brightness(0.55);
  }

  /* Hover overlay — title centered */
  .overlay {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.375rem;
    padding: 1.5rem;
    opacity: 0;
    transition: opacity 300ms ease;
  }

  .work-card:hover .overlay { opacity: 1; }

  .overlay-title {
    font-family: var(--font-family-display);
    font-size: clamp(0.8rem, 1.5vw, 1rem);
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #fff;
    text-align: center;
  }

  .overlay-client {
    font-family: var(--font-family-display);
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.5);
    text-align: center;
  }

  /* Always-visible client credit beneath image */
  .card-caption {
    font-family: var(--font-family-display);
    font-size: 0.62rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-muted);
    padding: 0.5rem 0 0;
    transition: color 200ms ease;
  }

  .work-card:hover .card-caption {
    color: var(--color-accent);
  }
</style>

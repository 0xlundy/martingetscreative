---
const year = new Date().getFullYear();
---

<footer>
  <div class="footer-inner">

    <div class="footer-left">
      <a href="/" class="footer-logo">MGC</a>
      <p class="footer-tagline">Martin Gets Creative</p>
    </div>

    <div class="footer-right">
      <a href="mailto:martinvanlonden@gmail.com" class="footer-email">
        martinvanlonden@gmail.com
      </a>
      <div class="social-links">
        <a href="https://instagram.com/martin_van_londen" target="_blank" rel="noopener noreferrer" class="s-link">IG</a>
        <a href="https://linkedin.com/in/" target="_blank" rel="noopener noreferrer" class="s-link">LinkedIn</a>
      </div>
    </div>

  </div>

  <div class="footer-bottom">
    <p>&copy; {year} Martin Van Londen</p>
  </div>
</footer>

<style>
  footer {
    border-top: 1px solid var(--color-border);
    margin-top: 4rem;
  }

  .footer-inner {
    max-width: 1440px;
    margin-inline: auto;
    padding: 2.5rem 2rem;
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: center;
    gap: 2rem;
  }

  .footer-logo {
    display: block;
    font-family: var(--font-family-display);
    font-weight: 800;
    font-size: 1rem;
    letter-spacing: 0.1em;
    color: var(--color-accent);
    margin-bottom: 0.375rem;
    text-decoration: none;
  }

  .footer-tagline {
    font-family: var(--font-family-display);
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-muted);
  }

  .footer-right {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.5rem;
  }

  .footer-email {
    font-size: 0.95rem;
    color: var(--color-muted);
    transition: color 150ms ease;
  }

  .footer-email:hover { color: var(--color-accent); }

  .social-links { display: flex; gap: 1.25rem; }

  .s-link {
    font-family: var(--font-family-display);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-muted);
    transition: color 150ms ease;
  }

  .s-link:hover { color: var(--color-text); }

  .footer-bottom {
    max-width: 1440px;
    margin-inline: auto;
    padding: 1rem 2rem;
    border-top: 1px solid var(--color-border);
    font-size: 0.82rem;
    color: var(--color-muted);
    font-family: var(--font-family-display);
    letter-spacing: 0.05em;
  }

  @media (max-width: 640px) {
    .footer-inner { grid-template-columns: 1fr; gap: 1.5rem; text-align: center; }
    .footer-right { align-items: center; }
  }
</style>

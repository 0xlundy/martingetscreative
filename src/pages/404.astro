---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Page not found | Martin Van Londen"
  description="That page doesn't exist. Head back to the work."
>
  <section class="nf">
    <div class="nf-inner">
      <p class="nf-eyebrow">404</p>
      <h1 class="nf-title">Lost the frame.</h1>
      <p class="nf-body">That page doesn't exist, or it moved. Try one of these instead.</p>
      <div class="nf-links">
        <a href="/" class="nf-link">Home →</a>
        <a href="/work" class="nf-link">Work →</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .nf {
    min-height: calc(100vh - 64px);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 4rem 2rem;
  }
  .nf-inner {
    max-width: 640px;
    text-align: center;
  }
  .nf-eyebrow {
    font-family: var(--font-family-display);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 1.5rem;
  }
  .nf-title {
    font-family: var(--font-family-display);
    font-weight: 800;
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    line-height: 0.95;
    letter-spacing: -0.02em;
    margin-bottom: 1.25rem;
  }
  .nf-body {
    font-size: 1rem;
    line-height: 1.7;
    color: var(--color-muted);
    margin-bottom: 2.5rem;
  }
  .nf-links {
    display: flex;
    justify-content: center;
    gap: 2rem;
    flex-wrap: wrap;
  }
  .nf-link {
    font-family: var(--font-family-display);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-accent);
    transition: opacity 150ms ease;
  }
  .nf-link:hover { opacity: 0.7; }
</style>

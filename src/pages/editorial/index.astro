---
// /editorial now redirects to /work#editorial.
// Kept as a stub so the route still resolves at the static build step;
// Netlify serves a 301 via netlify.toml at the edge.
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>Redirecting…</title>
    <meta http-equiv="refresh" content="0; url=/work#editorial" />
    <link rel="canonical" href="https://martingetscreative.com/work" />
  </head>
  <body>
    <p>Moved to <a href="/work#editorial">/work</a>.</p>
    <script>window.location.replace('/work#editorial');</script>
  </body>
</html>

  <meta name="description" content="Commercial photography and cinematography portfolio of Martin Van Londen — portraits, on-set documentary, editorial stories, and product work. Based in Portland, OR. Available worldwide." />
  <link rel="canonical" href="https://martingetscreative.com/editorial" />

  <!-- Open Graph -->
  <meta property="og:type"        content="website" />
  <meta property="og:url"         content="https://martingetscreative.com/editorial" />
  <meta property="og:title"       content="Commercial Work — Martin Van Londen | Cinematographer & Photographer" />
  <meta property="og:description" content="Commercial photography and cinematography portfolio of Martin Van Londen — portraits, on-set documentary, editorial stories, and product work." />
  <meta property="og:image"       content="https://martingetscreative.com/images/portraits/01-dscf3979.jpg" />
  <meta property="og:image:alt"   content="Editorial portrait by Martin Van Londen" />

  <!-- Twitter / X -->
  <meta name="twitter:card"        content="summary_large_image" />
  <meta name="twitter:title"       content="Commercial Work — Martin Van Londen" />
  <meta name="twitter:description" content="Commercial photography and cinematography portfolio — portraits, on-set, editorial stories, and product work. Portland, OR." />
  <meta name="twitter:image"       content="https://martingetscreative.com/images/portraits/01-dscf3979.jpg" />

  <!-- Structured data: ImageGallery -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "ImageGallery",
    "name": "Commercial Work — Martin Van Londen",
    "description": "Commercial photography and cinematography portfolio by Martin Van Londen",
    "url": "https://martingetscreative.com/editorial",
    "author": {
      "@type": "Person",
      "name": "Martin Van Londen",
      "url": "https://martingetscreative.com"
    }

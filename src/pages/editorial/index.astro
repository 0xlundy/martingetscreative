  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { background: #0a0a0a; color: #f0f0f0; font-family: sans-serif; }
    .site-nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 100;
      display: flex; justify-content: space-between; align-items: center;
      padding: 1.5rem 2rem;
      background: rgba(10,10,10,0.9);
    }
    .site-nav a { color: #f0f0f0; text-decoration: none; font-size: 0.75rem; letter-spacing: 0.15em; text-transform: uppercase; }
    .site-nav .logo { font-weight: 700; color: #e6420a; }
    .nav-links { display: flex; gap: 2rem; }
    .gallery-hero {
      padding: 8rem 2rem 3rem;
      text-align: center;
    }
    .gallery-hero h1 {
      font-size: clamp(2rem, 6vw, 5rem);
      letter-spacing: 0.15em;
      color: #f0f0f0;
    }
    .gallery-hero .subtitle {
      font-size: 0.75rem;
      letter-spacing: 0.2em;
      color: #888;
      text-transform: uppercase;
      margin-top: 0.5rem;
    }
    .act { margin-bottom: 5rem; }
    .act-header {
      padding: 0.75rem 1.5rem;
      margin-bottom: 3px;
      display: flex;
      align-items: baseline;
      gap: 1rem;
    }
    .act-number {
      font-size: 0.65rem;
      letter-spacing: 0.25em;
      color: #e6420a;
      text-transform: uppercase;
    }
    .act-title {
      font-size: 0.75rem;
      letter-spacing: 0.2em;
      color: #888;
      text-transform: uppercase;
    }

    /* Full-width images */
    .full-width {
      display: block;
      width: 100%;
      margin-bottom: 3px;
    }
    .full-width img {
      width: 100%;
      height: auto;
      display: block;
      transition: opacity 0.3s ease;
    }
    .full-width:hover img { opacity: 0.85; }

    /* Paired side-by-side row */
    .pair-row {
      column-span: all;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 3px;
      margin-bottom: 3px;
    }
    .pair-row a {
      position: relative;
      display: block;
      overflow: hidden;
      background: #111;
    }
    .pair-row img {
      width: 100%;
      height: auto;
      display: block;
      transition: opacity 0.3s ease;
    }
    .pair-row a:hover img { opacity: 0.85; }
    .pair-row a:hover .img-overlay { opacity: 1; }

    /* Masonry column layout */
    .gallery-grid {
      columns: 2;
      column-gap: 3px;
    }
    .gallery-grid a {
      position: relative;
      display: block;
      break-inside: avoid;
      margin-bottom: 3px;
      overflow: hidden;
      background: #111;
    }
    .gallery-grid img {
      width: 100%;
      height: auto;
      display: block;
      transition: opacity 0.3s ease;
    }
    .gallery-grid a:hover img { opacity: 0.85; }

    /* Hover overlay */
    .img-overlay {
      position: absolute;
      bottom: 0; left: 0; right: 0;
      background: linear-gradient(transparent, rgba(0,0,0,0.72));
      padding: 2.5rem 0.85rem 0.85rem;
      opacity: 0;
      transition: opacity 0.25s ease;
      pointer-events: none;
    }
    .gallery-grid a:hover .img-overlay { opacity: 1; }
    .img-title {
      display: block;
      color: #f0f0f0;
      font-size: 0.65rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      font-weight: 600;
    }
    .img-desc {
      display: block;
      color: #aaa;
      font-size: 0.6rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      margin-top: 0.2rem;
    }

    @media (max-width: 640px) {
      .gallery-grid { columns: 1; }
    }
  </style>
</head>

---
import BaseLayout from '../layouts/BaseLayout.astro';
import VideoEmbed from '../components/VideoEmbed.astro';
import { getCollection } from 'astro:content';

// ── Swap this with your real Vimeo ID ──────────────────────────
const REEL_VIMEO_ID = '901325832';
// ───────────────────────────────────────────────────────────────

// ── Selected Projects — lead roles, shown in this order ────────
// Each entry resolves to a case-study page. Add a vimeoId/youtubeId
// in the project's .md frontmatter to enable a video hero + card play.
const editorial = await getCollection('editorial');
const personal  = await getCollection('personal');
const pick = (coll: typeof editorial, slug: string) => coll.find((e) => e.slug === slug);

const showcase = [
  { entry: pick(editorial, 'make-it-here'),   base: 'editorial' },
  { entry: pick(editorial, 'cine-rent-west'), base: 'editorial' },
  { entry: pick(personal,  'against-the-code'), base: 'personal' },
]
  .filter((x) => x.entry)
  .map(({ entry, base }) => ({
    href:     `/${base}/${entry!.slug}`,
    title:    entry!.data.title,
    role:     entry!.data.role,
    status:   entry!.data.status,
    cover:    entry!.data.cover,
    coverAlt: entry!.data.coverAlt ?? entry!.data.title,
    hasVideo: Boolean(entry!.data.vimeoId || entry!.data.youtubeId || entry!.data.video),
  }));
---

<BaseLayout
  title="Cinematographer & Commercial Photographer Portland OR | Martin Van Londen"
  description="Portland, OR cinematographer and commercial photographer with twenty years creating campaign, documentary, and editorial content. Available for projects worldwide."
>

  <!-- ══ REEL ════════════════════════════════════════════════ -->
  <section class="reel-section">
    <div class="reel-wrap">
      <VideoEmbed vimeoId={REEL_VIMEO_ID} title="Martin Van Londen Reel" />
    </div>
  </section>

  <!-- ══ ABOUT ═══════════════════════════════════════════════ -->
  <section class="about-section">
    <div class="about-inner">

      <div class="about-left">
        <div class="name-block">
          <h1 class="name">Martin<br/>Van Londen</h1>
          <div class="avail-badge">
            <span class="avail-dot" aria-hidden="true"></span>
            Available for Projects
          </div>
        </div>
        <div class="about-meta">
          <p class="meta-line">Cinematography · Photography · Strategy</p>
          <p class="meta-line">Portland, OR. Available Worldwide.</p>
          <a href="mailto:martinvanlonden@gmail.com" class="meta-email">
            martinvanlonden@gmail.com
          </a>
        </div>
      </div>

      <div class="about-right">
        <p class="bio-lead">Twenty years behind the frame. I know what makes a story land, and how to build the shot that gets it there.</p>
        <p class="bio-body">Director, DP, and commercial photographer based in Portland, Oregon. My documentary work has been supported by the Andy Warhol Foundation. On the commercial side, I've shot campaigns and editorial content for clients across the Pacific Northwest and beyond. I think in strategy as much as images. I produce content and direct social, not just shoot and edit. Available worldwide for the right project.</p>
        <div class="about-links">
          <a href="/work" class="about-link">View Work →</a>
        </div>
      </div>

    </div>
  </section>


  <!-- ══ SERVICES ═════════════════════════════════════════════ -->
  <section class="services-section">
    <div class="services-inner">
      <p class="services-label">How to activate me on your project</p>
      <div class="services-grid">
        <div class="service-item">
          <span class="service-title">Cinematography</span>
          <span class="service-detail">Camera Department Key Creative</span>
        </div>
        <div class="service-item">
          <span class="service-title">Editorial Photography</span>
          <span class="service-detail">Lead Commercial Photographer, Documentary Photography, Photo Producer, Art Direction, Retouching</span>
        </div>
        <div class="service-item">
          <span class="service-title">Editorial</span>
          <span class="service-detail">Documentary Editing, Social Media Editing, Post Supervision</span>
        </div>
        <div class="service-item">
          <span class="service-title">Strategy</span>
          <span class="service-detail">Content Production, Post Strategy, Social Media Direction, Campaign Planning, Narrative Interview Writing</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ══ SELECTED PROJECTS ════════════════════════════════════ -->
  <section class="projects-section">
    <div class="projects-inner">
      <p class="projects-label">Selected Projects</p>
      <div class="projects-grid">
        {showcase.map((p) => (
          <a href={p.href} class="project-card">
            <div class="project-media">
              {p.cover ? (
                <img src={p.cover} alt={p.coverAlt} loading="lazy" />
              ) : (
                <span class="project-placeholder">{p.title}</span>
              )}
              {p.status && <span class="project-status">{p.status}</span>}
              {p.hasVideo && (
                <span class="project-play" aria-hidden="true">
                  <svg viewBox="0 0 24 24" width="20" height="20"><path d="M8 5v14l11-7z" fill="currentColor"/></svg>
                </span>
              )}
            </div>
            <div class="project-info">
              <span class="project-name">{p.title}</span>
              {p.role && <span class="project-role">{p.role}</span>}
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ WORK TILES ══════════════════════════════════════════ -->
  <section class="work-tiles">
    <a href="/work#editorial" class="tile">
      <span class="tile-label">Editorial</span>
      <span class="tile-sub">Event &amp; BTS</span>
    </a>
    <a href="/work#commissioned" class="tile">
      <span class="tile-label">Commissioned</span>
      <span class="tile-sub">Client Work</span>
    </a>
    <a href="/work#street" class="tile">
      <span class="tile-label">Field Notes</span>
      <span class="tile-sub">Observational</span>
    </a>
    <a href="/work#conceptual" class="tile">
      <span class="tile-label">Conceptual</span>
      <span class="tile-sub">Studio &amp; Self-Directed</span>
    </a>
  </section>

</BaseLayout>

<!-- JSON-LD: Person schema for SEO -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "Martin Van Londen",
  "jobTitle": "Cinematographer & Commercial Photographer",
  "url": "https://martingetscreative.com",
  "email": "martinvanlonden@gmail.com",
  "description": "Portland, OR cinematographer and commercial photographer with twenty years of experience creating campaign, documentary, and brand content for global clients.",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Portland",
    "addressRegion": "OR",
    "addressCountry": "US"
  },
  "knowsAbout": ["Commercial Photography", "Cinematography", "Documentary Photography", "Campaign Photography", "Photo Direction", "Video Production", "Content Production", "Social Media Direction", "Post Production", "Creative Strategy"]
}
</script>

<style>
  /* ─── Reel ──────────────────────────── */
  .reel-section {
    padding-top: 64px; /* nav height */
  }

  .reel-wrap {
    width: 100%;
  }

  /* Override VideoEmbed border-radius for full-bleed feel */
  .reel-wrap :global(.video-facade) {
    border-radius: 0;
  }

  /* ─── About ─────────────────────────── */
  .about-section {
    border-bottom: 1px solid var(--color-border);
  }

  .about-inner {
    max-width: 1440px;
    margin-inline: auto;
    padding: 5rem 2rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    align-items: start;
  }

  /* Left */
  .name-block {
    margin-bottom: 2.5rem;
  }

  .name {
    font-family: var(--font-family-display);
    font-weight: 800;
    font-size: clamp(3rem, 6vw, 5.5rem);
    line-height: 0.92;
    letter-spacing: -0.02em;
    margin-bottom: 1.25rem;
  }

  .avail-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-family-display);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-muted);
  }

  .avail-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background-color: #00d0bf;
    box-shadow: 0 0 6px #00d0bf88;
    animation: pulse 2.5s ease infinite;
    flex-shrink: 0;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0.4; }
  }

  .about-meta {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .meta-line {
    font-family: var(--font-family-display);
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-muted);
  }

  .meta-email {
    font-size: 0.95rem;
    color: var(--color-accent);
    transition: opacity 150ms ease;
  }

  .meta-email:hover { opacity: 0.7; }

  /* Right */
  .bio-lead {
    font-size: 1.25rem;
    line-height: 1.6;
    color: var(--color-text);
    margin-bottom: 1.25rem;
  }

  .bio-body {
    font-size: 1rem;
    line-height: 1.75;
    color: var(--color-muted);
    margin-bottom: 1rem;
  }

  .about-links {
    display: flex;
    gap: 2rem;
    margin-top: 2rem;
  }

  .about-link {
    font-family: var(--font-family-display);
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-accent);
    transition: opacity 150ms ease;
  }

  .about-link:hover { opacity: 0.7; }


  /* Services */
  .services-section { border-bottom: 1px solid var(--color-border); }
  .services-inner { max-width: 1440px; margin-inline: auto; padding: 3.5rem 2rem; }
  .services-label { font-family: var(--font-family-display); font-size: 0.82rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: var(--color-muted); margin-bottom: 2rem; }
  .services-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 2rem; }
  .service-item { display: flex; flex-direction: column; gap: 0.5rem; }
  .service-title { font-family: var(--font-family-display); font-size: 0.98rem; font-weight: 700; color: var(--color-text); }
  .service-detail { font-size: 0.92rem; line-height: 1.6; color: var(--color-muted); }
  @media (max-width: 860px) { .services-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 640px) { .services-grid { grid-template-columns: 1fr; } .services-inner { padding: 2.5rem 1.5rem; } }

  /* ─── Selected Projects ──────────────── */
  .projects-section { border-bottom: 1px solid var(--color-border); }
  .projects-inner { max-width: 1440px; margin-inline: auto; padding: 3.5rem 2rem; }
  .projects-label { font-family: var(--font-family-display); font-size: 0.82rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: var(--color-muted); margin-bottom: 2rem; }
  .projects-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; }
  .project-card { display: flex; flex-direction: column; text-decoration: none; }
  .project-media { position: relative; aspect-ratio: 4 / 3; overflow: hidden; background-color: var(--color-surface); border: 1px solid var(--color-border); }
  .project-media img { width: 100%; height: 100%; object-fit: cover; transition: transform 400ms ease; }
  .project-card:hover .project-media img { transform: scale(1.04); }
  .project-placeholder { position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; text-align: center; padding: 1.5rem; font-family: var(--font-family-display); font-weight: 800; font-size: clamp(1.1rem, 2vw, 1.6rem); letter-spacing: -0.01em; color: var(--color-muted); background: linear-gradient(135deg, var(--color-surface), #0d0d0d); }
  .project-status { position: absolute; top: 0.75rem; left: 0.75rem; display: inline-flex; align-items: center; gap: 0.4rem; font-family: var(--font-family-display); font-size: 0.62rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: var(--color-text); background: rgba(7,7,7,0.7); -webkit-backdrop-filter: blur(8px); backdrop-filter: blur(8px); border: 1px solid var(--color-border); padding: 0.3rem 0.55rem; border-radius: 2px; }
  .project-play { position: absolute; inset: 0; margin: auto; width: 52px; height: 52px; display: flex; align-items: center; justify-content: center; color: #fff; background: rgba(7,7,7,0.55); border: 1px solid rgba(255,255,255,0.4); border-radius: 50%; -webkit-backdrop-filter: blur(4px); backdrop-filter: blur(4px); transition: background 200ms ease, transform 200ms ease; }
  .project-card:hover .project-play { background: var(--color-accent); transform: scale(1.08); }
  .project-info { display: flex; flex-direction: column; gap: 0.3rem; padding-top: 1rem; }
  .project-name { font-family: var(--font-family-display); font-size: 1.05rem; font-weight: 700; color: var(--color-text); transition: color 200ms ease; }
  .project-card:hover .project-name { color: var(--color-accent); }
  .project-role { font-family: var(--font-family-display); font-size: 0.78rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: var(--color-muted); }
  @media (max-width: 860px) { .projects-grid { grid-template-columns: 1fr; } }
  @media (max-width: 640px) { .projects-inner { padding: 2.5rem 1.5rem; } }

  /* ─── Work tiles ─────────────────────── */
  .work-tiles {
    display: grid;
    grid-template-columns: 1fr 1fr;
    border-bottom: 1px solid var(--color-border);
  }

  .tile {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 4rem 2rem;
    border-right: 1px solid var(--color-border);
    text-decoration: none;
    transition: background-color 200ms ease;
    container-type: inline-size;
  }

  .tile:last-child { border-right: none; }
  .tile:hover { background-color: var(--color-surface); }

  .tile-label {
    font-family: var(--font-family-display);
    font-size: clamp(1.2rem, 6cqi, 3.5rem);
    font-weight: 800;
    color: var(--color-text);
    letter-spacing: -0.02em;
    display: block;
    margin-bottom: 0.5rem;
    transition: color 200ms ease;
  }

  .tile:hover .tile-label { color: var(--color-accent); }

  .tile-sub {
    font-family: var(--font-family-display);
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-muted);
    display: block;
  }

  /* ─── Responsive ─────────────────────── */
  @media (max-width: 860px) {
    .about-inner {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
  }

  @media (max-width: 640px) {
    .about-inner { padding: 3rem 1.5rem; }

    /* keep the name to two lines on phones: Martin / Van Londen */
    .name { font-size: clamp(2rem, 9vw, 3rem); white-space: nowrap; }

    .work-tiles { grid-template-columns: 1fr; }

    .tile {
      border-right: none;
      border-bottom: 1px solid var(--color-border);
      padding: 3rem 1.5rem;
    }

    .tile:last-child { border-bottom: none; }
  }
</style>

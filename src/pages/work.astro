---
import BaseLayout from '../layouts/BaseLayout.astro';
import { work, categories, type WorkItem, type Category } from '../data/work';

type Block =
  | { type: 'single'; item: WorkItem }
  | { type: 'shoot';  shoot: string; items: WorkItem[] };

function groupByShoot(items: WorkItem[]): Block[] {
  const blocks: Block[] = [];
  const seen = new Set<string>();
  for (const item of items) {
    if (item.shoot) {
      if (seen.has(item.shoot)) continue;
      seen.add(item.shoot);
      const all = items.filter(i => i.shoot === item.shoot);
      if (all.length > 1) {
        blocks.push({ type: 'shoot', shoot: item.shoot, items: all });
        continue;
      }
    }
    blocks.push({ type: 'single', item });
  }
  return blocks;
}

const orderedBlocks: { category: Category; blocks: Block[] }[] = categories.map(c => ({
  category: c.id,
  blocks: groupByShoot(work.filter(w => w.category === c.id)),
}));

const defaultCategory: Category = 'editorial';
---

<BaseLayout
  title="Work — Martin Van Londen | Cinematographer and Commercial Photographer Portland OR"
  description="Editorial, commissioned, street, and conceptual photography by Martin Van Londen. Portland, Oregon. Available worldwide."
>
  <section class="work-hero">
    <h1 class="work-title">WORK</h1>
    <p class="work-sub">Cinematography. Photography. Editorial.</p>

    <div class="filter-bar" role="tablist" aria-label="Filter work by category">
      {categories.map(c => (
        <button
          type="button"
          class:list={['filter-chip', { 'is-active': c.id === defaultCategory }]}
          data-filter={c.id}
          role="tab"
          aria-selected={c.id === defaultCategory ? 'true' : 'false'}
        >
          {c.label}
        </button>
      ))}
    </div>
  </section>

  <div class="work-grid" id="work-grid">
    {orderedBlocks.map(({ category, blocks }) => (
      blocks.map(block => (
        block.type === 'shoot' ? (
          <div class="work-tile shoot-row" data-category={category} data-shoot={block.shoot}>
            {block.items.map(it => (
              <a href={it.src} target="_blank" class="work-item shoot-item">
                <img src={it.src} alt={it.alt} />
                <div class="img-overlay">
                  <span class="img-title">{it.title}</span>
                  <span class="img-desc">{it.desc}</span>
                </div>
              </a>
            ))}
          </div>
        ) : (
          <a
            href={block.item.src}
            target="_blank"
            class:list={['work-tile work-item', { 'is-wide': block.item.wide }]}
            data-category={category}
          >
            <img src={block.item.src} alt={block.item.alt} />
            <div class="img-overlay">
              <span class="img-title">{block.item.title}</span>
              <span class="img-desc">{block.item.desc}</span>
            </div>
          </a>
        )
      ))
    ))}
  </div>

  <p class="work-empty" id="work-empty" hidden>Nothing in this category yet. Check back soon.</p>
</BaseLayout>

<!-- JSON-LD: ImageGallery -->
<script type="application/ld+json" set:html={JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'ImageGallery',
  name: 'Work — Martin Van Londen',
  description: 'Editorial, commissioned, street, and conceptual photography by Martin Van Londen',
  url: 'https://martingetscreative.com/work',
  author: {
    '@type': 'Person',
    name: 'Martin Van Londen',
    url: 'https://martingetscreative.com',
  },
})} />

<script>
  const chips = document.querySelectorAll<HTMLButtonElement>('.filter-chip');
  const grid  = document.getElementById('work-grid') as HTMLElement | null;
  const empty = document.getElementById('work-empty');
  const valid = ['editorial', 'commissioned', 'street', 'conceptual'];

  // Row sizing — tiles span N rows of ROW_PX each.
  const ROW_PX = 10;
  const GAP_PX = 3;
  const COL_COUNT = 2;

  function aspect(img: HTMLImageElement): number {
    if (img.naturalWidth && img.naturalHeight) return img.naturalWidth / img.naturalHeight;
    return 3 / 4; // placeholder portrait-ish ratio
  }

  function computeTileHeight(tile: HTMLElement, colWidth: number): number {
    const imgs = tile.querySelectorAll<HTMLImageElement>('img');
    if (tile.classList.contains('shoot-row')) {
      // Shoot rows are full grid width (span all columns)
      const rowWidth = colWidth * COL_COUNT + GAP_PX * (COL_COUNT - 1);
      const gapTotal = GAP_PX * (imgs.length - 1);
      const usable = rowWidth - gapTotal;
      let sumAspect = 0;
      imgs.forEach(img => { sumAspect += aspect(img); });
      if (sumAspect === 0) return rowWidth * 0.4;
      return usable / sumAspect;
    } else if (tile.classList.contains('is-wide')) {
      // Wide single: full grid width
      const rowWidth = colWidth * COL_COUNT + GAP_PX * (COL_COUNT - 1);
      const img = imgs[0];
      if (!img) return rowWidth * 0.4;
      return rowWidth / aspect(img);
    } else {
      // Single image, 1 col wide
      const img = imgs[0];
      if (!img) return colWidth * 0.75;
      return colWidth / aspect(img);
    }
  }

  function applyMasonry() {
    if (!grid) return;
    const gridWidth = grid.clientWidth;
    const totalGap = GAP_PX * (COL_COUNT - 1);
    const colWidth = (gridWidth - totalGap) / COL_COUNT;

    grid.querySelectorAll<HTMLElement>('.work-tile').forEach(tile => {
      if (tile.style.display === 'none') return;
      const h = computeTileHeight(tile, colWidth);
      const span = Math.max(1, Math.ceil((h + GAP_PX) / (ROW_PX + GAP_PX)));
      tile.style.gridRowEnd = `span ${span}`;

      // For shoot rows, set each item's flex based on its aspect ratio so all
      // images share the same height across the row.
      if (tile.classList.contains('shoot-row')) {
        tile.querySelectorAll<HTMLElement>('.shoot-item').forEach(item => {
          const im = item.querySelector('img') as HTMLImageElement | null;
          if (im) item.style.flexGrow = String(aspect(im));
        });
      }
    });
  }

  function applyFilter(filter: string) {
    if (!grid) return;
    const tiles = grid.querySelectorAll<HTMLElement>('.work-tile');
    let visible = 0;
    tiles.forEach(el => {
      const match = el.dataset.category === filter;
      el.style.display = match ? '' : 'none';
      if (match) visible++;
    });
    if (empty) empty.hidden = visible > 0;

    chips.forEach(c => {
      const active = c.dataset.filter === filter;
      c.classList.toggle('is-active', active);
      c.setAttribute('aria-selected', String(active));
    });

    history.replaceState(null, '', '#' + filter);
    applyMasonry();
  }

  chips.forEach(c => {
    c.addEventListener('click', () => applyFilter(c.dataset.filter || 'editorial'));
  });

  const initialHash = window.location.hash.replace('#', '');
  applyFilter(valid.includes(initialHash) ? initialHash : 'editorial');

  if (grid) {
    grid.querySelectorAll('img').forEach(img => {
      if (img.complete) return;
      img.addEventListener('load',  applyMasonry, { once: true });
      img.addEventListener('error', applyMasonry, { once: true });
    });
  }

  let resizeTimer: number | undefined;
  window.addEventListener('resize', () => {
    if (resizeTimer) window.clearTimeout(resizeTimer);
    resizeTimer = window.setTimeout(applyMasonry, 80);
  });

  window.addEventListener('hashchange', () => {
    const h = window.location.hash.replace('#', '');
    if (valid.includes(h)) applyFilter(h);
  });
</script>

<style>
  /* ─── Hero ─────────────────────────────────────── */
  .work-hero {
    padding: 7rem 2rem 2rem;
    text-align: center;
  }

  .work-title {
    font-family: var(--font-family-display);
    font-weight: 800;
    font-size: clamp(2.5rem, 6vw, 5rem);
    letter-spacing: 0.12em;
    color: var(--color-text);
  }

  .work-sub {
    font-family: var(--font-family-display);
    font-size: 0.72rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-muted);
    margin-top: 0.75rem;
  }

  /* ─── Filter bar ───────────────────────────────── */
  .filter-bar {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.5rem;
    margin-top: 2.5rem;
    padding: 0 1rem;
  }

  .filter-chip {
    font-family: var(--font-family-display);
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    padding: 0.55rem 1.1rem;
    border: 1px solid var(--color-border);
    background: transparent;
    color: var(--color-muted);
    border-radius: 2px;
    cursor: pointer;
    transition: color 150ms ease, border-color 150ms ease, background 150ms ease;
  }

  .filter-chip:hover {
    color: var(--color-text);
    border-color: var(--color-text);
  }

  .filter-chip.is-active {
    color: var(--color-bg);
    background: var(--color-accent);
    border-color: var(--color-accent);
  }

  /* ─── Row-span Grid Masonry ────────────────────── */
  /* Singles take 1 column, shoot rows span both columns and lay out their
     items as a horizontal flex row. grid-auto-flow: dense backfills empty
     cells with later 1-col singles, eliminating dead gaps. */
  .work-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-auto-rows: 10px;
    grid-auto-flow: dense;
    gap: 3px;
    padding: 2rem 0 5rem;
  }

  .work-tile {
    grid-row-end: span 30; /* placeholder; JS overrides */
    overflow: hidden;
  }

  a.work-item {
    position: relative;
    display: block;
    overflow: hidden;
    background: #111;
    height: 100%;
  }

  .work-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: opacity 0.3s ease;
  }

  .work-item:hover img { opacity: 0.85; }

  /* Wide single: spans full grid width */
  .work-tile.is-wide {
    grid-column: 1 / -1;
  }

  /* Shoot rows span the full grid width as a horizontal flex row.
     Each item's flex-grow is set to its aspect ratio so all images share
     the same height. */
  .shoot-row {
    grid-column: 1 / -1;
    display: flex;
    flex-direction: row;
    gap: 3px;
    align-items: stretch;
  }

  .shoot-item {
    flex-grow: 1;
    flex-basis: 0;
    min-width: 0;
    overflow: hidden;
    position: relative;
    background: #111;
  }

  /* ─── Overlay ──────────────────────────────────── */
  .img-overlay {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    background: linear-gradient(transparent, rgba(0,0,0,0.72));
    padding: 2.5rem 0.85rem 0.85rem;
    opacity: 0;
    transition: opacity 0.25s ease;
    pointer-events: none;
  }

  .work-item:hover .img-overlay { opacity: 1; }

  .img-title {
    display: block;
    color: #f0f0f0;
    font-size: 0.65rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    font-weight: 600;
  }

  .img-desc {
    display: block;
    color: #aaa;
    font-size: 0.6rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-top: 0.2rem;
  }

  /* ─── Empty state ──────────────────────────────── */
  .work-empty {
    text-align: center;
    padding: 4rem 2rem;
    font-family: var(--font-family-display);
    font-size: 0.8rem;
    letter-spacing: 0.1em;
    color: var(--color-muted);
  }

  /* ─── Responsive ───────────────────────────────── */
  @media (max-width: 640px) {
    .work-grid { grid-template-columns: 1fr; }
    .filter-chip { font-size: 0.62rem; padding: 0.45rem 0.85rem; }
    .shoot-row { flex-direction: column; }
  }
</style>
